# Required for sync:
FIREFLIES_API_KEY=

# Optional (improves answer quality and summaries):
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Use only if your network TLS proxy causes SELF_SIGNED_CERT_IN_CHAIN:
FIREFLIES_ALLOW_INSECURE_TLS=0

# Reasoning model for final answer synthesis:
# `openai` (default) or `ollama` (local)
RAG_REASONING_PROVIDER=openai
# Optional override model for chosen provider:
RAG_REASONING_MODEL=
RAG_REASONING_TEMPERATURE=0.1
RAG_REASONING_MAX_OUTPUT_TOKENS=700
# Local Ollama settings (only used when RAG_REASONING_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_FALLBACK_TO_OPENAI=1
OLLAMA_TIMEOUT_MS=120000
OLLAMA_NO_CLOUD=1
OLLAMA_REGISTRY_MAXSTREAMS=1
OLLAMA_NUM_CTX=8192
OLLAMA_TOP_P=0.9
OLLAMA_TOP_K=40
OLLAMA_REPEAT_PENALTY=1.15
OLLAMA_REPEAT_LAST_N=128

# Optional Microsoft To-Do integration (requires outbound Microsoft Graph access):
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
# Add your callback URL in Azure app registration and set this value to match:
# Example: http://127.0.0.1:8788/api/integrations/microsoft/callback
MICROSOFT_REDIRECT_URI=

# Local-only defaults:
FIREFLIES_RAG_HOST=127.0.0.1
PORT=8788
RAG_SQLITE_PATH=apps/server/data/fireflies_rag.sqlite
RAG_EMBEDDINGS_PROVIDER=local
RAG_LOCAL_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
RAG_TOP_K=8
RAG_MULTIUSER_ENABLED=0
FIREFLIES_STRICT_USER_SCOPE=0
FIREFLIES_DEFAULT_USER_ID=local

# Strict egress mode (blocks outbound HTTP/S except optional Fireflies pull):
LOCAL_ONLY_MODE=1
# Keep LOCAL_ONLY_MODE on, but allow Fireflies pull-only ingress:
ALLOW_FIREFLIES_PULL=0
# Optional: allow Microsoft To-Do sync endpoints in local-only mode.
# This permits outbound calls to login.microsoftonline.com and graph.microsoft.com.
ALLOW_MICROSOFT_TODO_SYNC=0
TRANSFORMERS_OFFLINE=1
HF_HUB_OFFLINE=1
HF_DATASETS_OFFLINE=1
HF_HUB_DISABLE_TELEMETRY=1

# Optional auto-sync scheduler:
# Every N minutes (0 disables background loop)
FIREFLIES_SYNC_INTERVAL_MINUTES=0
# Run one scheduled sync shortly after server start (when interval > 0 this just starts the loop quickly)
FIREFLIES_SYNC_ON_STARTUP=0
# Per-run fetch cap for background loop (0 = full catch-up)
FIREFLIES_SYNC_LIMIT=50
# Optional sync window in local hour (24h clock). Example overnight: start=20, end=7
FIREFLIES_SYNC_WINDOW_START_HOUR=
FIREFLIES_SYNC_WINDOW_END_HOUR=
# Optional IANA timezone for the window, e.g. America/New_York. Blank = machine local time.
FIREFLIES_SYNC_WINDOW_TIMEZONE=
# Delay between transcript detail pulls; higher values reduce API pressure.
FIREFLIES_SYNC_THROTTLE_MS=1000
